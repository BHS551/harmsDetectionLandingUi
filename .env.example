# ─── Pasarela de pago ───────────────────────────────────────────────────────
# Por defecto se usa PayU. Pon "stripe" SOLO si quieres usar Stripe.
PAYMENT_PROVIDER=payu

# ─── PayU Latam (WebCheckout) ───────────────────────────────────────────────
# Credenciales del panel de PayU (Configuración > Configuración técnica).
PAYU_MERCHANT_ID=
PAYU_ACCOUNT_ID=
PAYU_API_KEY=
# URL de la pasarela. Sandbox (por defecto):
#   https://sandbox.checkout.payulatam.com/ppp-web-gateway-payu/
# Producción:
#   https://checkout.payulatam.com/ppp-web-gateway-payu/
PAYU_CHECKOUT_URL=https://sandbox.checkout.payulatam.com/ppp-web-gateway-payu/
# "1" = modo prueba (por defecto), "0" = pagos reales.
PAYU_TEST=1

# ─── Stripe (solo si PAYMENT_PROVIDER=stripe) ───────────────────────────────
# Clave secreta de Stripe (Dashboard > Developers > API keys).
STRIPE_SECRET_KEY=sk_test_...
# Signing secret del webhook (Dashboard > Developers > Webhooks > tu endpoint).
# El endpoint debe apuntar a  <tu-dominio>/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# URL base pública de la app, usada para los success/cancel de Checkout.
# En local: http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── Firebase Admin (webhook + verificación de tokens) ──────────────────────
# Valores del JSON de la cuenta de servicio de Firebase
# (Console > Configuración del proyecto > Cuentas de servicio).
FIREBASE_PROJECT_ID=login-69a8a
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@login-69a8a.iam.gserviceaccount.com
# La clave privada va entre comillas y con los saltos de línea escapados (\n).
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── AWS (ya existente, para /api/screenshots) ──────────────────────────────
AWS_REGION=us-east-1
S3_BUCKET_NAME=
S3_PREFIX=
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY vía entorno
